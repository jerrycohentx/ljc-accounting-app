logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS & editor
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
.idea/
.vscode/
*.code-workspace

# Generated / copied seed for Vite static serve
public/data/

