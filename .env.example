# Copy to .env and fill in values ( .env is gitignored )
PORT=3000
NODE_ENV=development
JWT_SECRET=change-me-in-production
FRONTEND_URL=http://localhost:3000

# Plaid (https://dashboard.plaid.com) — Simmons Bank only; use sandbox while testing
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
# Simmons Bank institution ID(s) — default ins_111008; comma-separate OAuth variants if needed
# PLAID_SIMMONS_INSTITUTION_IDS=ins_111008
# Optional: separate key for encrypting stored bank tokens (defaults to JWT_SECRET)
# PLAID_TOKEN_KEY=
# Optional: public URL for Plaid webhooks (Render: https://your-app.onrender.com/api/plaid/webhook)
# PLAID_WEBHOOK_URL=
