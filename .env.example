# Copy to .env and fill in values ( .env is gitignored )
PORT=3000
NODE_ENV=development
JWT_SECRET=change-me-in-production
FRONTEND_URL=http://localhost:3000

# Auto backup (local SQLite → db/backups/; Postgres → pg_dump or JSON snapshot)
# BACKUP_INTERVAL_MINUTES=60
# BACKUP_RETENTION_COUNT=30
# DISABLE_AUTO_BACKUP=1

# Plaid (https://dashboard.plaid.com) — Simmons Bank, American Express, Ramp
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
# SANDBOX: All Plaid institutions return FAKE test transactions (not your real Ramp/Amex/Simmons accounts).
# For real Simmons/Amex/Ramp data: see integration/PLAID-PRODUCTION-SETUP.md
# (PLAID_ENV=production, production PLAID_SECRET, PLAID_REDIRECT_URI in Plaid Dashboard, restart app)
# Allowed Plaid institution IDs (comma-separated). Defaults include Simmons, Amex, Ramp.
# PLAID_ALLOWED_INSTITUTION_IDS=ins_111008,ins_10,ins_137213,ins_138097
# Required for OAuth institutions — must also be listed in Plaid Dashboard → Allowed redirect URIs
# PLAID_REDIRECT_URI=http://localhost:3000/bank-import
# Legacy Simmons-only override (merged into defaults when PLAID_ALLOWED_INSTITUTION_IDS unset)
# PLAID_SIMMONS_INSTITUTION_IDS=ins_111008
# Optional: separate key for encrypting stored bank tokens (defaults to JWT_SECRET)
# PLAID_TOKEN_KEY=
# Optional: public URL for Plaid webhooks (Render: https://your-app.onrender.com/api/plaid/webhook)
# PLAID_WEBHOOK_URL=
# Required for Simmons Bank OAuth (register same URL in Plaid Dashboard → API → Allowed redirect URIs)
# PLAID_REDIRECT_URI=http://localhost:3000/bank-import

# ---------------------------------------------------------------------------
# Shellpoint mortgage statement email ingest (multi-mailbox)
#
# Preferred: STATEMENT_EMAIL_ACCOUNTS JSON array (one entry per mailbox).
# Legacy fallback: STATEMENT_EMAIL_USER + STATEMENT_EMAIL_PASSWORD (single mailbox).
#
# WHEN YOU ROTATE AN APP PASSWORD:
#   1. Google: Account → Security → 2-Step Verification → App passwords
#   2. Microsoft 365: Security → App passwords (if MFA enabled)
#   3. Update password in STATEMENT_EMAIL_ACCOUNTS (or run scripts/update-statement-email-password.ps1 -Email user@domain)
#   4. Restart the app (close + relaunch START-APP.bat) so the server reloads .env
#
# See integration/STATEMENT-EMAIL.md for full steps.
# ---------------------------------------------------------------------------

# Multi-mailbox config (preferred). Each object: user, password, optional label/host/port/folder.
#
# Auth method per mailbox (see integration/STATEMENT-EMAIL.md):
#   documents.ljcfinancial@gmail.com  → Gmail OAuth API (GMAIL_OAUTH_ACCOUNTS) preferred; IMAP app password fallback
#   jerrycohentx@gmail.com            → Gmail OAuth API (same client, separate refresh_token)
#   jerry@ljcfinancial.com            → Microsoft 365 IMAP (outlook.office365.com) OR Graph API when IMAP blocked
#
# Omit host to auto-detect: gmail.com → imap.gmail.com; custom domains try Google then M365.
STATEMENT_EMAIL_ACCOUNTS=[{"label":"documents","user":"documents.ljcfinancial@gmail.com","password":"","host":"imap.gmail.com"},{"label":"jerrycohentx","user":"jerrycohentx@gmail.com","password":"","host":"imap.gmail.com"},{"label":"jerry","user":"jerry@ljcfinancial.com","password":"","host":"outlook.office365.com"}]

# Legacy single-mailbox (used only when STATEMENT_EMAIL_ACCOUNTS is unset)
# STATEMENT_EMAIL_HOST=imap.gmail.com
# STATEMENT_EMAIL_PORT=993
# STATEMENT_EMAIL_USER=documents.ljcfinancial@gmail.com
# STATEMENT_EMAIL_PASSWORD=
# STATEMENT_EMAIL_FOLDER=INBOX
# STATEMENT_EMAIL_PROCESSED_FOLDER=Processed
# Set true to scan inboxes automatically when the server starts (dev/sandbox)
# STATEMENT_EMAIL_SCAN_ON_STARTUP=true

# NEVER use 1Password CLI (`op`) in this project — triggers "Allow Cursor Agents" prompts.
# All secrets belong in .env above. See .cursor/rules/ljc-zero-secrets-cli.mdc.

# Per-mailbox password override (avoids JSON/special-char issues). Optional _B64 suffix for base64.
# STATEMENT_EMAIL_PASSWORD_DOCUMENTS='your-google-app-password'
# STATEMENT_EMAIL_PASSWORD_JERRY='your-m365-app-password'

# ---------------------------------------------------------------------------
# Gmail OAuth — multiple @gmail.com mailboxes (preferred over app password)
#
# Works with passkey / 2FA accounts. One-time Google Cloud setup + OAuth consent
# per mailbox. Same GMAIL_OAUTH_CLIENT_ID/SECRET for all Gmail accounts.
# See integration/GMAIL-OAUTH-SETUP.md
# ---------------------------------------------------------------------------
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_OAUTH_REDIRECT_URI=https://ljc-accounting-app.onrender.com/api/email/gmail/callback
GMAIL_OAUTH_USER=documents.ljcfinancial@gmail.com
# Legacy single-token fallback (also updated when documents@ completes OAuth):
# GMAIL_OAUTH_REFRESH_TOKEN=
# Multi-Gmail OAuth (preferred). One refresh_token per user after consent:
GMAIL_OAUTH_ACCOUNTS=[{"label":"documents","user":"documents.ljcfinancial@gmail.com","refresh_token":""},{"label":"jerrycohentx","user":"jerrycohentx@gmail.com","refresh_token":""}]

# ---------------------------------------------------------------------------
# Microsoft Graph — jerry@ljcfinancial.com (M365 IMAP blocked at tenant)
#
# 2026 bank/CRE/tax statements arrive at jerry@ — NOT documents@ Gmail OAuth.
# One-time Azure app registration + admin consent. See integration/M365-GRAPH-SETUP.md
# Interim: forward jerry@ → documents@ (integration/STATEMENT-EMAIL.md)
# ---------------------------------------------------------------------------
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_MAILBOX_USER=jerry@ljcfinancial.com

# ---------------------------------------------------------------------------
# Document Capture — automated capture of financial documents
# from all connected Gmail OAuth mailboxes (documents@, jerrycohentx@, …).
#
# Reuses the GMAIL_OAUTH_* credentials above for the live email scan. No new
# secrets required. See integration/DOCUMENT-CAPTURE.md.
# ---------------------------------------------------------------------------
# Optional: enable image-receipt OCR (off by default — pipeline degrades to
# NEEDS_REVIEW for images when disabled; no heavy/native OCR dependency).
# DOCUMENT_CAPTURE_OCR_ENABLED=false

# ---------------------------------------------------------------------------
# Loan Tracker → Cohen Accounting (holdback draw auto-export)
# Set the same key in the loan tracker sidebar (Cohen Accounting settings).
# ---------------------------------------------------------------------------
# LOAN_TRACKER_INTEGRATION_KEY=ljc-cohen-loan-tracker-2026
# LOAN_TRACKER_USER_EMAIL=demo@ljcfinancial.com

# ---------------------------------------------------------------------------
# Password reset — SMS verification codes (Twilio)
# https://www.twilio.com — get Account SID, Auth Token, and a phone number
# ---------------------------------------------------------------------------
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+15551234567
# Jerry's mobile (E.164) — password reset texts
ADMIN_PHONE=+12818317855
# Optional per-email overrides: {"jerry@ljcfinancial.com":"+12145551234"}
# PASSWORD_RESET_PHONES={"jerry@ljcfinancial.com":"+12145551234"}

# ---------------------------------------------------------------------------
# Lone Star Bank eStatement auto-download (notification emails without PDF)
#
# Lone Star sends "eStatement …7367 is ready to view" from info@lsbtexas.com.
# The app logs into my.lsbtexas.com and downloads the PDF when that email arrives.
# Use a NetTeller ID dedicated to automation (2FA/passkey will block headless login).
# ---------------------------------------------------------------------------
# LONESTAR_ONLINE_USER=
# LONESTAR_ONLINE_PASSWORD=
# LONESTAR_ACCOUNT_LAST4=7367
# LONESTAR_PORTAL_URL=https://my.lsbtexas.com

# Legacy email reset (unused when Twilio is configured):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
