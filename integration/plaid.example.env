# Plaid integration — Simmons Bank ONLY (not Lone Star Bank)
# Get keys from https://dashboard.plaid.com/developers/keys

PLAID_CLIENT_ID=your_sandbox_client_id
PLAID_SECRET=your_sandbox_secret
PLAID_ENV=sandbox

# Simmons Bank Plaid institution ID (verify in Plaid Dashboard → Institutions search "Simmons Bank")
PLAID_SIMMONS_INSTITUTION_IDS=ins_111008

# Production on Render:
# PLAID_WEBHOOK_URL=https://ljc-accounting-app.onrender.com/api/plaid/webhook

# Optional separate encryption key for stored bank tokens:
# PLAID_TOKEN_KEY=long-random-string

# Note: plaid-cli (brew install plaid/plaid-cli/plaid) is macOS/Linux only.
# This app uses the Node Plaid SDK — no CLI required on Windows.

# Lone Star Bank: use OFX file upload on the Bank Import page (not Plaid).
